# Database Configuration
# MongoDB Atlas connection string (get from https://cloud.mongodb.com)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
DB_NAME=fab_finance

# Security
# Generate a strong random string (32+ characters)
JWT_SECRET=change_this_to_a_strong_random_secret_minimum_32_characters

# AI Provider Keys (tries in order: Groq → Gemini → OpenAI)
# Get free API keys from:
# - Groq: https://console.groq.com
# - Gemini: https://makersuite.google.com/app/apikey
# - OpenAI: https://platform.openai.com/api-keys
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Frontend URL (Update with your Render frontend URL after deployment)
FRONTEND_URL=https://fab-finance-frontend.onrender.com

# Email/OTP Configuration
# Option A — Brevo SMTP (recommended for local dev)
# 1. Create free account at https://www.brevo.com
# 2. Verify your sender email under Senders & IP
# 3. Create SMTP key under SMTP & API → SMTP
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=2525
SMTP_EMAIL=your-brevo-smtp-login@smtp-brevo.com
SMTP_PASSWORD=your-brevo-smtp-key
SENDER_EMAIL=your-verified-email@gmail.com

# Option B — Resend HTTP API (recommended for Render — SMTP ports are blocked)
# Get key at https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=FIN TRACKER <your-verified-email@gmail.com>

# Option C — Gmail SMTP (local dev only)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=your-email@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SENDER_EMAIL=your-email@gmail.com

# Bank JSON Path (Leave as default)
BANK_JSON_PATH=./bank.json

# Local Development URLs
# MONGODB_URI=mongodb://localhost:27017
# FRONTEND_URL=http://localhost:3000
